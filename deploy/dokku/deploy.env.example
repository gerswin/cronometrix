# Cronometrix Dokku deploy config — copy to deploy.env and fill in.
# deploy.env is gitignored.

# Host
SSH_USER=gerswin
SSH_HOST=192.168.0.44

# Dokku SSH port for `git push`. 22 if Dokku is installed natively on the host.
# 3022 (default) if Dokku runs inside a Docker container with port 3022:22 mapped.
# Find with: docker port dokku 22
DOKKU_SSH_PORT=3022

# Apps
API_APP=cronometrix-api
WEB_APP=cronometrix-web

# Public domains (DNS A records must point to SSH_HOST's public IP)
API_DOMAIN=demo-api.cronometrix.app
WEB_DOMAIN=app-demo.cronometrix.app

# Let's Encrypt contact
LE_EMAIL=g3rswin@gmail.com

# Backend secrets
# Generate once with: openssl rand -hex 32   (then KEEP IT — rotating logs everyone out)
JWT_SECRET=CHANGEME_64hex_chars

# AES-256 key used to encrypt device credentials at rest. Must decode to exactly
# 32 bytes via base64. Generate once with: openssl rand -base64 32
# Rotating this invalidates ALL stored device passwords — keep it stable.
DEVICE_CREDS_KEY=CHANGEME_base64_32bytes

# Turso (OPTIONAL)
# Leave BOTH blank to run local-only SQLite (still persisted via dokku
# storage:mount on /opt/cronometrix/data). Recommended for demo deployments —
# avoids embedded-replica sync races during initial migration apply.
# Fill BOTH to enable embedded replica + cloud sync.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Demo mode (true = bypass license + block /__test_reset at nginx)
DEMO_MODE=true

# Set true to skip Let's Encrypt (LAN-only or DNS not ready yet)
SKIP_LE=false

# Branch to push (defaults to main)
GIT_BRANCH=main
