# Cronometrix — plantilla para arranque LOCAL en Docker.
# Copiar a `.env.local` y rellenar los valores marcados con CHANGEME.
#
#   cp .env.local.example .env.local
#   docker compose -f docker-compose.local.yml --env-file .env.local up --build
# La aplicación queda disponible únicamente en http://localhost:8080.

# ── Auth (obligatorios) ─────────────────────────────────────────────────────
# Secreto HS256 para firmar JWT de acceso. Generar con:
#   openssl rand -base64 48
JWT_SECRET=CHANGEME_generate_with_openssl_rand_base64_48

# Bytes para la cookie de refresh (httpOnly). Generar con:
#   openssl rand -base64 48
REFRESH_TOKEN_SECRET=CHANGEME_generate_with_openssl_rand_base64_48

# Clave AES-GCM (32 bytes base64) para cifrar credenciales ISAPI de Hikvision
# en reposo. Generar con:
#   openssl rand -base64 32
DEVICE_CREDS_KEY=CHANGEME_generate_with_openssl_rand_base64_32

# ── Turso sync (opcional en local — déjalo vacío para puro SQLite local) ────
# Si tienes una base Turso, puedes apuntar el cliente. Vacío = solo local.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── DO Functions de licencia (NO requeridos por bypass) ────────────────────
# Vacíos en local porque CRONOMETRIX_LICENSE_BYPASS=true salta la validación.
DO_FUNCTIONS_ACTIVATE_URL=
DO_FUNCTIONS_RENEW_URL=

# Public key para validar JWT de licencia. En local con bypass se ignora.
LICENSE_PUBKEY_PATH=/opt/cronometrix/data/license_pubkey.pem
