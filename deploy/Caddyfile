# Cronometrix — single-origin reverse proxy for tunneling demos.
# Routes /api/* to the Rust/Axum backend (port 3001) and everything else
# to the Next.js frontend (port 3000). One public URL, no CORS, no cookie
# SameSite issues. Pair with `cloudflared tunnel --url http://localhost:8080`.
#
# Usage:
#   caddy run --config deploy/Caddyfile

:8080 {
    encode gzip

    handle /api/* {
        reverse_proxy localhost:3001 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # SSE stream needs flushing and no buffering; keep alive long enough
    # for the dashboard's event ring buffer.
    handle /api/v1/events/stream {
        reverse_proxy localhost:3001 {
            flush_interval -1
            transport http {
                read_timeout 24h
            }
        }
    }

    handle {
        reverse_proxy localhost:3000
    }
}
