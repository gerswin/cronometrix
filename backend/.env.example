CRONOMETRIX_DB_PATH=cronometrix.db
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here
JWT_SECRET=your-secret-key-at-least-32-characters-long
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
TURSO_SYNC_INTERVAL=300

# AES-256-GCM key for device credential encryption (D-02).
# MUST be 32 bytes, base64-encoded. Generate with:
#   head -c 32 /dev/urandom | base64
# NEVER reuse JWT_SECRET.
DEVICE_CREDS_KEY=

# CORS allow-list — comma-separated list of frontend origins permitted to send
# credentialed requests (auth cookies). MUST be explicit; `*` is rejected by
# browsers when cookies are involved.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Refresh-cookie Secure flag.
# Dev (http://localhost): false — browsers drop Secure cookies on non-HTTPS.
# Production (https://...): true — keep enabled to prevent leaking the cookie over plain HTTP.
COOKIE_SECURE=true
