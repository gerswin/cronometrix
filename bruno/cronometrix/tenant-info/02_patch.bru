meta {
  name: patch tenant info
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/api/v1/tenant-info
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "client_name": "Acme Industria CA",
    "client_rif": "J-12345678-9",
    "address": "Caracas, Venezuela",
    "version": {{tenant_info_version}}
  }
}
